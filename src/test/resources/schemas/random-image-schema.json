{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Random Image Response",
  "type": "object",
  "required": ["message", "status"],
  "properties": {
    "message": {
      "type": "string",
      "format": "uri",
      "description": "URL of a random dog image"
    },
    "status": {
      "type": "string",
      "enum": ["success"],
      "description": "Response status indicator"
    }
  },
  "additionalProperties": false
}
