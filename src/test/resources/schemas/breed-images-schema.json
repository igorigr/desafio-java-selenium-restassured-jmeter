{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Breed Images Response",
  "type": "object",
  "required": ["message", "status"],
  "properties": {
    "message": {
      "type": "array",
      "description": "Array of image URLs for the requested breed",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "minItems": 1
    },
    "status": {
      "type": "string",
      "enum": ["success"],
      "description": "Response status indicator"
    }
  },
  "additionalProperties": false
}
